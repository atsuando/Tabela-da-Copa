{
  "manifest_version": 3,
  "name": "Tabela da Copa",
  "version": "1.2",
  "description": "Adiciona um botão flutuante para ver a tabela da Copa do Mundo a qualquer momento.",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}